#
#  gdal.netcore package automation
#
#    MacOS Runtime Identifier
#
BASE=$(PWD)
BASE_RID=osx
TARGET_OS=$(BASE_RID)
BUILD_ARCH=arm64
VCPKG_RID=$(BUILD_ARCH)-$(BASE_RID)

# .NET RID
RID=$(BASE_RID)-$(BUILD_ARCH)
SWIG=swig
SHELL=/bin/bash

SED=gsed
DEL_DIR=rm -rf
OSX_DEPLOYMENT_TARGET=11.0

# Platform-specific library variables
LIB_PATH_VAR=DYLD_FALLBACK_LIBRARY_PATH
LIB_EXT=dylib