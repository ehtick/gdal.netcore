          "features": [
            "tool",
            "rtree"
          ]
        },
        "libiconv",
        "lz4",
        "liblzma",
        {
          "name": "libjxl",
          "features": [
            "tools"
          ]
        },
        "blosc",
        "cryptopp",
        {
          "name": "arrow",
          "features": [
            "parquet"
          ]
        }
      ]
